# Supabase — apenas chaves públicas no frontend
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Cloudinary — apenas cloud name é público
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=seu-cloud-name

# WhatsApp — número da vendedora com DDI (sem espaços, traços ou parênteses)
NEXT_PUBLIC_WHATSAPP_NUMBER=5522999999999

# Nome da loja (usado em SEO e Open Graph)
NEXT_PUBLIC_STORE_NAME=Nome da Loja
NEXT_PUBLIC_STORE_CITY=Araruama
NEXT_PUBLIC_STORE_STATE=RJ
